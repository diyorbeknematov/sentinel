# Server Configuration
HTTP_PORT=8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=rdpassword
REDIS_DB=0

# JWT Tokens
ACCESS_TOKEN=your-secret-access-token-key
REFRESH_TOKEN=your-secret-refresh-token-key

# Frontend URL (used for password reset links)
FRONTEND_URL=http://localhost:5173

# SMTP Mailer Configuration
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USERNAME=your-email@gmail.com
MAILER_PASSWORD=your-app-password
MAILER_FROM=noreply@sentinel.com

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=test-topic
KAFKA_GROUP_ID=test-group
